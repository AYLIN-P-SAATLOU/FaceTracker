
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FaceRecognizerApp.Views.MainWindow"
        Title="Face Tracker &amp; Privacy Mask"
        Width="800" Height="650"
        Topmost="True" 
        WindowStartupLocation="CenterScreen">
    
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
        <TextBlock Name="FaceCountLabel" FontSize="24" FontWeight="Bold" Foreground="DarkOrange" 
                   HorizontalAlignment="Center" Text="Faces Detected: 0"/>
        
        <Border Background="Black" CornerRadius="10" ClipToBounds="True">
            <Image Name="CameraDisplay" Width="640" Height="480" Stretch="Uniform"/>
        </Border>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
            <Button Name="StartButton" Content="Start Camera" Background="Green" Foreground="White" Padding="15,5"/>
            <Button Name="StopButton" Content="Stop Camera" Background="DarkRed" Foreground="White" Padding="15,5"/>
            <CheckBox Name="BlurCheckBox" Content="Enable Privacy Mask" IsChecked="False" VerticalAlignment="Center"/>
        </StackPanel>
    </StackPanel>
</Window>